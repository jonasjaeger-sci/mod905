units       lj
boundary p p p
atom_style  full 
pair_style  lj/cut 2.5
read_data system.data
pair_coeff  1 1 1.0 1.0 2.5
pair_modify tail yes
neighbor    0.3 bin
include order.in
thermo_style custom step pe ke etotal temp press density
thermo 100
thermo_modify norm no
timestep 0.005
variable SET_TEMP equal 1.0
fix 1 all nve
