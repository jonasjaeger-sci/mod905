&GLOBAL
  PROJECT TEST
  RUN_TYPE MD
  PRINT_LEVEL LOW
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    &SCF
      SCF_GUESS RESTART
      EPS_SCF 1.0E-5
      MAX_SCF 20
      &OT ON
        MINIMIZER DIIS
      &END OT
    &END SCF
    &QS
      EPS_DEFAULT 1.0E-5
      WF_INTERPOLATION PS
    &END QS
    &MGRID
      CUTOFF 280
      REL_CUTOFF 30
    &END MGRID
    &XC
      &XC_FUNCTIONAL PADE
      &END XC_FUNCTIONAL
    &END XC
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    POTENTIAL_FILE_NAME GTH_POTENTIALS
  &END DFT
  &SUBSYS
    &KIND C
      ELEMENT C
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND H
      ELEMENT H
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND N
      ELEMENT N
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q5
    &END KIND
    &CELL
      PERIODIC xyz
      ABC 5.0 5.0 5.0
      ALPHA_BETA_GAMMA 90.0 90.0 90.0
    &END CELL
    &TOPOLOGY
      COORD_FILE_NAME initial.xyz
      COORD_FILE_FORMAT xyz
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &MD
    STEPS 100
    TIMESTEP 0.5
    TEMPERATURE 500
  &END MD
  &PRINT
    &RESTART
      BACKUP_COPIES 0
      &EACH
        MD 444
      &END EACH
    &END RESTART
    &VELOCITIES
      &EACH
        MD 5
      &END EACH
    &END VELOCITIES
    &TRAJECTORY
      &EACH
        MD 5
      &END EACH
    &END TRAJECTORY
  &END PRINT
&END MOTION

