dimension 3
boundary p p p
atom_style atomic

# Simulation box and lattice:
lattice fcc 0.8442
region box block 0 5 0 5 0 5
create_box 3 box
create_atoms 1 box
set type 1 type/fraction 2 0.5 36423 # change 10% of type 1 to be type 2
set type 1* type/fraction 3 0.2 36423 # change 10% of type 1 to be type 3


# Atoms:
mass 1 1.0
mass 2 1.0
mass 3 1.5
neighbor 4.6 bin
neigh_modify every 1 check no
# Simulation parameters
timestep 0.0025
pair_style lj/cut 2.5
pair_coeff 1 1 1.0 1.0 
pair_coeff 2 2 1.1 1.2 
pair_coeff 3 3 0.9 1.4
pair_modify mix geometric
pair_modify shift yes 

velocity all create 1.7 12345 dist gaussian mom yes

dump dumptraj2 all custom 1 lj-unwrap.lammpstrj.bin id type xu yu zu vx vy vz fx fy fz 

fix 1 all nve
thermo 1
thermo_style custom step temp press pe ke etotal pxx pyy pzz pxy pxz pyz
run 1000

