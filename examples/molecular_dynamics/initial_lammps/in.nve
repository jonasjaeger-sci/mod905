dimension 3
boundary p p p
atom_style atomic

# Simulation box and lattice:
lattice fcc 0.8442
region box block 0 5 0 5 0 5
create_box 1 box
create_atoms 1 box

# Atoms:
mass 1 1.0
neighbor 4.6 bin
neigh_modify every 1 check no
# Simulation parameters
timestep 0.0025
pair_style lj/cut 2.5
pair_coeff 1 1 1.0 1.0 

velocity all create 1.7 12345 dist gaussian mom yes

dump dumptraj1 all custom 1 lj.lammpstrj.bin id x y z vx vy vz fx fy fz 
dump dumptraj2 all custom 1 lj-unwrap.lammpstrj.bin id xu yu zu vx vy vz fx fy fz 

fix 1 all nve
thermo 1
run 5000

