             <widget class="QCheckBox" name="dataShiftChkBtn">
              <property name="toolTip">
               <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;If checked will allow the program to shift the data periodically in order to reduce spread / increase linear correlation along either x- or y-axis, or both.&lt;br/&gt;Mostly useful in cases where one order parameter (OP) is an angle, and values loop from min to max, i.e. 180=-180 (or in radians, etc.)&lt;/p&gt;&lt;p&gt;Since the very first OP is used to define the reaction, this parameter - if chosen for plotting - will &lt;span style=&quot; font-weight:600;&quot;&gt;never&lt;/span&gt; be shifted, as this can cause major visual inconsistencies.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
              </property>
              <property name="text">
               <string>Data shift</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="intShowChkBtn">
              <property name="enabled">
               <bool>false</bool>
              </property>
              <property name="toolTip">
               <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;If checked will plot a set of interface lines (if 2D case) or planes (if 3D case) &lt;span style=&quot; font-weight:600;&quot;&gt;only&lt;/span&gt; when x-axis uses the order parameter defining the reaction (the very first OP).&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
              </property>
              <property name="text">
               <string>Interfaces</string>
              </property>
              <property name="tristate">
               <bool>false</bool>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="storedTrjsChkBtn">
              <property name="toolTip">
               <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Toggle this box to show only the cycles which have trajectory files availeable. These are the only cycles that can be recomputed.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
              </property>
              <property name="text">
               <string>Only stored trjs</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item>
